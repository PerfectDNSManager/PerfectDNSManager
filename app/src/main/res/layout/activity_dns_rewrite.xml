<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pdm_background"
    android:padding="16dp"
    tools:context=".DnsRewriteActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dns_rewrite_screen_title"
        android:textSize="22sp"
        android:textColor="@color/pdm_text_primary"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnAddRule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_new_rule"
        android:backgroundTint="@color/pdm_accent_info"
        android:foreground="@drawable/btn_focus_foreground"
        android:textColor="@color/pdm_text_primary"
        android:layout_marginBottom="16dp"
        android:focusable="true"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRewriteRules"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_dns_rewrite_rule" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/back_arrow"
        android:textSize="18sp"
        android:padding="12dp"
        android:minHeight="48dp"
        android:backgroundTint="@color/pdm_border"
        android:foreground="@drawable/btn_focus_foreground"
        android:layout_gravity="start"
        android:layout_marginTop="16dp"
        android:focusable="true"/>

</LinearLayout>
