<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <EditText
        android:id="@+id/etFromDomain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/source_domain_hint"
        android:inputType="textUri"
        android:textColor="@color/pdm_text_primary"
        android:textColorHint="@color/pdm_text_disabled"
        android:background="@drawable/edit_text_background"
        android:padding="10dp"
        android:focusable="true"/>

    <EditText
        android:id="@+id/etToDomain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/dest_domain_hint"
        android:layout_marginTop="16dp"
        android:inputType="textUri"
        android:textColor="@color/pdm_text_primary"
        android:textColorHint="@color/pdm_text_disabled"
        android:background="@drawable/edit_text_background"
        android:padding="10dp"
        android:focusable="true"/>

</LinearLayout>
