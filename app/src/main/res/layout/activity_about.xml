<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pdm_background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_arrow"
            android:textSize="18sp"
            android:padding="12dp"
            android:minHeight="48dp"
            android:backgroundTint="@color/pdm_surface_elevated"
            android:foreground="@drawable/btn_focus_foreground"
            android:textColor="@color/pdm_text_primary"
            android:layout_gravity="start"
            android:layout_marginBottom="16dp"
            android:focusable="true"
            android:nextFocusDown="@+id/btnSupportAbout"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_title"
            android:textColor="@color/pdm_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Texte communautaire -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_community_text"
            android:textColor="@color/pdm_text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:background="@color/pdm_tint_neutral"
            android:padding="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- Bouton soutenir (juste sous le texte communautaire) -->
        <Button
            android:id="@+id/btnSupportAbout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/support_about_button"
            android:background="@drawable/pdm_btn_support"
            android:foreground="@drawable/btn_focus_foreground"
            android:textColor="@color/pdm_accent_support"
            android:layout_marginBottom="20dp"
            android:focusable="true"
            android:nextFocusUp="@id/btnBack"
            android:nextFocusDown="@+id/btnCheckForUpdate"/>

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/pdm_text_disabled"
            android:textSize="15sp"
            android:layout_marginBottom="8dp"
            android:text="Version 1.0"/>

        <Button
            android:id="@+id/btnCheckForUpdate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/check_for_updates"
            android:background="@drawable/pdm_btn_info"
            android:foreground="@drawable/btn_focus_foreground"
            android:textColor="@color/pdm_accent_alt"
            android:layout_marginBottom="20dp"
            android:focusable="true"
            android:nextFocusUp="@id/btnSupportAbout"/>

        <!-- Licence GPL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/gpl_license_text"
            android:textColor="@color/pdm_accent"
            android:textSize="12sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:background="@color/pdm_tint_accent"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:autoLink="web"
            android:linksClickable="true"/>

    </LinearLayout>
</ScrollView>
