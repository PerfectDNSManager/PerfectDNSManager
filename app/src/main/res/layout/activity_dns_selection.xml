<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pdm_background"
    android:padding="16dp">

    <!-- Header : btnBack (start) + tvTitle (centré écran via spacer miroir
         à droite de même largeur). Sans le spacer, le titre se centre dans
         l'espace restant et apparaît décalé à droite par rapport au centre
         visuel de l'écran. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="@string/back_arrow"
            android:background="@drawable/focusable_item_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:textColor="@color/pdm_item_text"
            android:textSize="14sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:nextFocusDown="@id/btnSpeedtest" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/choose_dns_server"
            android:textColor="@color/pdm_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <!-- Spacer miroir : même largeur visuelle que btnBack, invisible.
             Permet au titre (weight=1, gravity center) d'être réellement
             centré sur l'écran et pas décalé à droite. -->
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="@string/back_arrow"
            android:textSize="14sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:visibility="invisible"
            android:focusable="false" />
    </LinearLayout>

    <!-- Info méthode -->
    <TextView
        android:id="@+id/tvMethodInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/pdm_accent_alt"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"
        android:padding="8dp"
        android:background="@color/pdm_tint_info" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnSpeedtest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dns_speedtest_shortcut"
            android:textColor="@color/pdm_accent_alt"
            android:background="@drawable/pdm_btn_info"
            android:foreground="@drawable/btn_focus_foreground"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:nextFocusRight="@id/btnAddProfile"
            android:nextFocusUp="@id/btnBack"
            android:nextFocusDown="@id/rvDnsList" />

        <Button
            android:id="@+id/btnAddProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/add_new_profile"
            android:textColor="@color/pdm_accent"
            android:background="@drawable/pdm_btn_primary"
            android:foreground="@drawable/btn_focus_foreground"
            android:focusable="true"
            android:nextFocusLeft="@id/btnSpeedtest"
            android:nextFocusUp="@id/btnBack"
            android:nextFocusDown="@id/rvDnsList" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDnsList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical"
        android:descendantFocusability="afterDescendants" />

</LinearLayout>
