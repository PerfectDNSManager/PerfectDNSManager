<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pdm_background"
    android:padding="16dp">

    <!-- Header : FrameLayout pour titre VRAIMENT centré sur l'écran sans
         bouffer d'espace par un spacer miroir. Le bouton RETOUR est en
         layout_gravity=start, le titre en layout_gravity=center. Le titre
         peut overlap visuellement le bouton sur très petit écran si vraiment
         long, mais on accepte (préférable à la troncature ellipsize). -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnBack"
            style="@style/PDMBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/back_arrow"
            android:nextFocusDown="@id/btnSpeedtest" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/choose_dns_server"
            android:textColor="@color/pdm_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1" />
    </FrameLayout>

    <!-- Info méthode -->
    <TextView
        android:id="@+id/tvMethodInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/pdm_accent_alt"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"
        android:padding="8dp"
        android:background="@color/pdm_tint_info" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnSpeedtest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dns_speedtest_shortcut"
            android:textColor="@color/pdm_accent_alt"
            android:background="@drawable/pdm_btn_info"
            android:foreground="@drawable/btn_focus_foreground"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:nextFocusRight="@id/btnAddProfile"
            android:nextFocusUp="@id/btnBack"
            android:nextFocusDown="@id/rvDnsList" />

        <Button
            android:id="@+id/btnAddProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/add_new_profile"
            android:textColor="@color/pdm_accent"
            android:background="@drawable/pdm_btn_primary"
            android:foreground="@drawable/btn_focus_foreground"
            android:focusable="true"
            android:nextFocusLeft="@id/btnSpeedtest"
            android:nextFocusUp="@id/btnBack"
            android:nextFocusDown="@id/rvDnsList" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDnsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:descendantFocusability="afterDescendants" />

</LinearLayout>
