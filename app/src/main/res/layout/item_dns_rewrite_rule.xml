<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@color/pdm_surface">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFromDomain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/pdm_text_primary"
            android:textSize="16sp"
            android:text="ygg.re"/>

        <TextView
            android:id="@+id/tvToDomain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/pdm_text_secondary"
            android:textSize="14sp"
            android:text="→ google.fr"/>

    </LinearLayout>

    <Switch
        android:id="@+id/switchEnableRule"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:focusable="true"
        android:foreground="@drawable/btn_focus_foreground"/>

    <ImageButton
        android:id="@+id/btnDeleteRule"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_delete"
        android:background="@drawable/focusable_item_background"
        android:layout_marginStart="8dp"
        android:focusable="true"/>

</LinearLayout>
