<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pdm_background"
    android:fillViewport="true">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_arrow"
            android:background="@drawable/focusable_item_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:textColor="@color/pdm_item_text"
            android:textSize="18sp"
            android:padding="12dp"
            android:minHeight="48dp"
            android:focusable="true" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/pdm_text_primary"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Sélecteur de thème (déplacé tout en haut) -->
    <LinearLayout
        android:id="@+id/rowTheme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/focusable_item_background"
        android:foreground="@drawable/btn_focus_foreground"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:focusable="true"
        android:clickable="true">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/theme_label"
            android:textColor="@color/pdm_text_primary"
            android:textSize="15sp"/>
        <TextView
            android:id="@+id/tvThemeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/pdm_accent_alt"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Section Démarrage auto (titre supprimé, doublon visuel inutile) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/pdm_section_card"
        android:padding="12dp"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:id="@+id/rowAutoStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/focusable_item_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:padding="8dp"
            android:layout_marginBottom="4dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_start_label"
                android:textColor="@color/pdm_text_primary"
                android:textSize="15sp"/>
            <Switch
                android:id="@+id/switchAutoStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/rowAutoReconnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/focusable_item_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:padding="8dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_reconnect_label"
                android:textColor="@color/pdm_text_primary"
                android:textSize="15sp"/>
            <Switch
                android:id="@+id/switchAutoReconnect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>
        <TextView
            android:id="@+id/tvAutoReconnectDns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/pdm_text_secondary"
            android:textSize="13sp"
            android:paddingStart="4dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>
        <LinearLayout
            android:id="@+id/rowDisableIpv6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/focusable_item_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:padding="8dp"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusUp="@id/rowAutoReconnect"
            android:nextFocusDown="@id/rowAdvanced">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/disable_ipv6_label"
                android:textColor="@color/pdm_text_primary"
                android:textSize="15sp"/>
            <Switch
                android:id="@+id/switchDisableIpv6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Section Paramètres DNS avancés -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/pdm_section_card"
        android:padding="12dp"
        android:layout_marginBottom="12dp">
        <LinearLayout
            android:id="@+id/rowAdvanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/focusable_item_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:padding="8dp"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusUp="@id/rowDisableIpv6"
            android:nextFocusDown="@id/rowImportExport">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/advanced_features_title"
                android:textColor="@color/pdm_accent_support"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <Switch
                android:id="@+id/switchAdvanced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>
        <!-- Contenu caché par défaut -->
        <LinearLayout
            android:id="@+id/layoutAdvancedSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp">

            <!-- 1. Sous-toggle variantes de profils -->
            <LinearLayout
                android:id="@+id/rowProfileVariants"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/focusable_item_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"
                android:focusable="true" >
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="@color/pdm_text_secondary"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_profile_variants"
                    android:textColor="@color/pdm_text_secondary"
                    android:textSize="14sp"/>
                <Switch
                    android:id="@+id/switchProfileVariants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"/>
            </LinearLayout>

            <!-- 2. Sous-toggle DNS over QUIC -->
            <LinearLayout
                android:id="@+id/rowDoqDns"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/focusable_item_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"
                android:focusable="true" >
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:tint="@color/pdm_text_secondary"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_doq_dns"
                    android:textColor="@color/pdm_text_secondary"
                    android:textSize="14sp"/>
                <Switch
                    android:id="@+id/switchDoqDns"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"/>
            </LinearLayout>

            <!-- 3. Sous-toggle DNS Standard -->
            <LinearLayout
                android:id="@+id/rowStandardDns"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/focusable_item_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"
                android:focusable="true" >
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="@color/pdm_text_secondary"
                    android:scaleType="fitCenter"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_standard_dns"
                    android:textColor="@color/pdm_text_secondary"
                    android:textSize="14sp"/>
                <Switch
                    android:id="@+id/switchStandardDns"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"/>
            </LinearLayout>

            <!-- 4. Sous-toggle DNS opérateur -->
            <LinearLayout
                android:id="@+id/rowOperatorDns"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/focusable_item_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"
                android:focusable="true" >
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_operator_dns"
                    android:textColor="@color/pdm_text_secondary"
                    android:textSize="14sp"/>
                <Switch
                    android:id="@+id/switchOperatorDns"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"/>
            </LinearLayout>

            <!-- 5. Sous-toggle DNS DoT via ADB — placé en dernier car l'encart
                 ADB juste en dessous se déploie quand on l'active. -->
            <LinearLayout
                android:id="@+id/rowAdbDot"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/focusable_item_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"
                android:focusable="true" >
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dns_dot_adb"
                    android:textColor="@color/pdm_text_secondary"
                    android:textSize="14sp"/>
                <Switch
                    android:id="@+id/switchAdbDot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:focusable="false"/>
            </LinearLayout>

            <!-- ADB sub-section (hidden, shown when switchAdbDot ON) -->
            <LinearLayout
                android:id="@+id/layoutAdbDotSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:background="@color/pdm_tint_neutral"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:id="@+id/tvAdbStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <Button
                        android:id="@+id/btnHowTo"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/how_to_adb"
                        android:background="@drawable/focusable_item_background"
                        android:foreground="@drawable/btn_focus_foreground"
                        android:textColor="@color/pdm_item_text"
                        android:textSize="13sp"
                        android:padding="8dp"
                        android:focusable="true" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_warning"
                    android:textColor="@color/pdm_danger"
                    android:textSize="12sp"
                    android:background="@color/pdm_tint_danger"
                    android:padding="8dp"/>

                <!-- Section Auto-permission ADB -->
                <LinearLayout
                    android:id="@+id/layoutSelfGrantSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"
                    android:background="@color/pdm_tint_accent"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/self_grant_section_title"
                        android:textColor="@color/pdm_accent"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/self_grant_section_desc"
                        android:textColor="@color/pdm_text_secondary"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvPermissionStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnSelfGrant"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/pdm_btn_primary"
                        android:foreground="@drawable/btn_focus_foreground"
                        android:textColor="@color/pdm_text_primary"
                        android:textSize="12sp"
                        android:focusable="true" />
                </LinearLayout>

            </LinearLayout>

            <!-- URL Rewrite warning -->
            <TextView
                android:id="@+id/tvUrlRewriteWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/url_rewrite_warning"
                android:textColor="@color/pdm_accent_gold"
                android:textSize="12sp"
                android:background="@color/pdm_tint_warning"
                android:padding="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnUrlRewrite"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/url_rewrite_button"
                android:background="@drawable/pdm_btn_primary"
                android:foreground="@drawable/btn_focus_foreground"
                android:textColor="@color/pdm_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"
                android:focusable="true" />

            <!-- Split tunneling (bypass VPN per-app) -->
            <Button
                android:id="@+id/btnSplitTunnel"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/split_tunnel_button"
                android:background="@drawable/pdm_btn_info"
                android:foreground="@drawable/btn_focus_foreground"
                android:textColor="@color/pdm_text_primary"
                android:textSize="14sp"
                android:focusable="true" />

        </LinearLayout>
    </LinearLayout>

    <!-- Import / Export (titre supprimé, doublon avec import_export_title) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/pdm_section_card"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/rowImportExport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/focusable_item_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:focusable="true"
            android:padding="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/import_export_title"
                android:textColor="@color/pdm_accent_alt"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvImportExportArrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textColor="@color/pdm_accent_alt"
                android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutImportExportContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp">
            <Button
                android:id="@+id/btnExportConfig"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/export_config_button"
                android:background="@drawable/pdm_btn_info"
                android:foreground="@drawable/btn_focus_foreground"
                android:textColor="@color/pdm_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"
                android:focusable="true" />
            <Button
                android:id="@+id/btnImportConfig"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/import_config_button"
                android:background="@drawable/pdm_btn_primary"
                android:foreground="@drawable/btn_focus_foreground"
                android:textColor="@color/pdm_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"
                android:focusable="true" />
            <Button
                android:id="@+id/btnRestoreDns"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="@string/restore_dns_button"
                android:background="@drawable/pdm_btn_info"
                android:foreground="@drawable/btn_focus_foreground"
                android:textColor="@color/pdm_text_primary"
                android:textSize="14sp"
                android:focusable="true" />
            <Button
                android:id="@+id/btnResetApp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/reset_app_button"
                android:background="@drawable/pdm_btn_danger"
                android:foreground="@drawable/btn_focus_foreground"
                android:textColor="@color/pdm_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableStart="@android:drawable/ic_dialog_alert"
                android:drawablePadding="8dp"
                android:layout_marginTop="12dp"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Mises à jour bêta — sa propre card, sortie de la section avancée -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/pdm_section_card"
        android:padding="12dp"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:id="@+id/rowBetaUpdates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/focusable_item_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:padding="8dp"
            android:focusable="true"
            android:clickable="true">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/beta_updates_label"
                    android:textColor="@color/pdm_text_primary"
                    android:textSize="15sp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/beta_updates_description"
                    android:textColor="@color/pdm_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <Switch
                android:id="@+id/switchBetaUpdates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- À propos (intégré ici en bas plutôt qu'une page séparée) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/pdm_section_card"
        android:padding="12dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_title"
            android:textColor="@color/pdm_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_community_text"
            android:textColor="@color/pdm_text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:background="@color/pdm_tint_neutral"
            android:padding="10dp"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btnSupportAbout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/support_about_button"
            android:background="@drawable/pdm_btn_support"
            android:foreground="@drawable/btn_focus_foreground"
            android:textColor="@color/pdm_accent_support"
            android:layout_marginBottom="8dp"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/pdm_text_disabled"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btnCheckForUpdate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/check_for_updates"
            android:background="@drawable/pdm_btn_info"
            android:foreground="@drawable/btn_focus_foreground"
            android:textColor="@color/pdm_accent_alt"
            android:layout_marginBottom="8dp"
            android:focusable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/gpl_license_text"
            android:textColor="@color/pdm_accent"
            android:textSize="11sp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:background="@color/pdm_tint_accent"
            android:padding="8dp"
            android:autoLink="web"
            android:linksClickable="true"/>
    </LinearLayout>
</LinearLayout>
</ScrollView>
