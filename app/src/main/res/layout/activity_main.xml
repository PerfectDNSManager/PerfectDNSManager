<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pdm_background"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- En-tete -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnLanguage"
            style="@style/PDMButton.Ghost"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:textColor="@color/pdm_text_primary"
            android:textSize="28sp"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minWidth="56dp"
            android:focusable="true"
            android:nextFocusRight="@id/btnSettings"
            android:nextFocusDown="@id/layoutSelectDns" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/PDMText.Subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnLanguage"
            android:layout_toStartOf="@id/btnSettings"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="@string/dns_switcher"
            android:textSize="16sp"
            android:textColor="@color/pdm_text_primary"
            android:letterSpacing="0.02"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/pdm_btn_secondary"
            android:src="@drawable/ic_settings"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:focusable="true"
            android:nextFocusLeft="@id/btnLanguage"
            android:nextFocusDown="@id/layoutSelectDns"
            android:contentDescription="@string/settings_content_description" />
    </RelativeLayout>

    <!-- 1| Fournisseur DNS -->
    <TextView
        android:id="@+id/tvDnsProviderLabel"
        style="@style/PDMText.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dns_provider_label"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/layoutSelectDns"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/pdm_btn_secondary"
        android:focusable="true"
        android:clickable="true"
        android:nextFocusUp="@id/btnLanguage"
        android:nextFocusDown="@id/rowActivationToggle">

        <ImageView
            android:id="@+id/ivSelectedDnsIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="10dp"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="@null"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tvSelectDns"
            style="@style/PDMText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dns_select_button"
            android:textColor="@color/pdm_accent"
            android:gravity="center"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▸"
            android:textColor="@color/pdm_text_secondary"
            android:textSize="18sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 2| Activation -->
    <TextView
        android:id="@+id/tvActivationLabel"
        style="@style/PDMText.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/activation_label"
        android:layout_marginBottom="4dp" />

    <!-- Toggle activation : row focusable + Switch (Android TV friendly).
         Le row capte le focus, le Switch lui-même n'est pas focusable seul.
         FrameLayout pour que le texte soit centré au milieu de la row,
         le Switch superposé à droite sans déplacer le texte. -->
    <FrameLayout
        android:id="@+id/rowActivationToggle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/pdm_btn_secondary"
        android:foreground="@drawable/btn_focus_foreground"
        android:focusable="true"
        android:clickable="true"
        android:layout_marginBottom="8dp"
        android:nextFocusUp="@id/layoutSelectDns"
        android:nextFocusDown="@id/btnGenerateReport">

        <TextView
            android:id="@+id/tvActivationStatus"
            style="@style/PDMText.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/activate"
            android:textColor="@color/pdm_accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swActivationToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:focusable="false"
            android:clickable="false" />
    </FrameLayout>

    <!-- Module outils (toujours visible — anciennement gated par swToolsToggle) -->
    <LinearLayout
        android:id="@+id/layoutToolsPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/pdm_card_bg"
        android:padding="10dp">

        <!-- Outils (gauche) + Rapport (droite) — swap fait après le déplacement des
             infos appareil dans le panneau status, pour aligner colonne outils sur
             colonne status info ci-dessous. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnDomainTester"
                style="@style/PDMButton"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/quick_dns_test_button"
                android:textSize="12sp"
                android:focusable="true"
                android:nextFocusUp="@id/rowActivationToggle"
                android:nextFocusRight="@id/btnGenerateReport"
                android:nextFocusDown="@id/btnSpeedtest" />

            <Button
                android:id="@+id/btnGenerateReport"
                style="@style/PDMButton.Primary"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/generate_report_button"
                android:textSize="12sp"
                android:focusable="true"
                android:nextFocusUp="@id/rowActivationToggle"
                android:nextFocusLeft="@id/btnDomainTester"
                android:nextFocusDown="@id/btnShareReport" />
        </LinearLayout>

        <!-- Speedtest (gauche) + Partager (droite) — symétrique row précédente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnSpeedtest"
                style="@style/PDMButton"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/internet_speedtest_advanced"
                android:textSize="12sp"
                android:focusable="true"
                android:nextFocusUp="@id/btnDomainTester"
                android:nextFocusRight="@id/btnShareReport"
                android:nextFocusDown="@id/wrapReport" />

            <Button
                android:id="@+id/btnShareReport"
                style="@style/PDMButton.Primary"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/share_report_button"
                android:textSize="12sp"
                android:focusable="true"
                android:nextFocusUp="@id/btnGenerateReport"
                android:nextFocusLeft="@id/btnSpeedtest"
                android:nextFocusDown="@id/wrapReport" />
        </LinearLayout>

        <!-- Zone résultats split en 2 (50/50 strict, weightSum + baselineAligned=false
             pour éviter qu'un long contenu wrap_content bouffe la moitié de l'autre) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2"
            android:baselineAligned="false"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp">

            <!-- Left: Status — 3 cards empilées (DNS actif + profil / Connexion+IPs / Hardware) -->
            <LinearLayout
                android:id="@+id/wrapStatus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/cardStatusDns"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/pdm_card_bg"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvStatusDns"
                        style="@style/PDMText.Body"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/no_active_dns"
                        android:textSize="12sp"
                        android:lineSpacingExtra="1dp"
                        android:textColor="@color/pdm_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardStatusConn"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/pdm_card_bg"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvStatusConn"
                        style="@style/PDMText.Body"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textSize="12sp"
                        android:lineSpacingExtra="1dp"
                        android:textColor="@color/pdm_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardStatusDevice"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/pdm_card_bg"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvStatusDevice"
                        style="@style/PDMText.Body"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textSize="12sp"
                        android:lineSpacingExtra="1dp"
                        android:textColor="@color/pdm_text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: Report — 3 cards empilées (Blocking / Leak / Speedtest).
                 wrapReport reste focusable (focus stop pour D-pad TV depuis btnSpeedtest/btnShareReport),
                 sans scroll interne — chaque card est dimensionnée pour fit son contenu. -->
            <LinearLayout
                android:id="@+id/wrapReport"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:orientation="vertical"
                android:focusable="true"
                android:descendantFocusability="blocksDescendants"
                android:nextFocusUp="@id/btnShareReport">

                <LinearLayout
                    android:id="@+id/cardReportBlocking"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/pdm_card_bg"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvReportBlocking"
                        style="@style/PDMText.Body"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/no_report_yet"
                        android:textSize="12sp"
                        android:lineSpacingExtra="1dp"
                        android:textColor="@color/pdm_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardReportLeak"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="4dp"
                    android:orientation="vertical"
                    android:background="@drawable/pdm_card_bg"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvReportLeak"
                        style="@style/PDMText.Body"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textSize="12sp"
                        android:lineSpacingExtra="1dp"
                        android:textColor="@color/pdm_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardReportSpeedtest"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/pdm_card_bg"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvReportSpeedtest"
                        style="@style/PDMText.Body"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textSize="12sp"
                        android:lineSpacingExtra="1dp"
                        android:textColor="@color/pdm_text_secondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
