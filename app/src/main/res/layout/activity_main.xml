<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pdm_background"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- En-tete -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnLanguage"
            style="@style/PDMButton.Ghost"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:textColor="@color/pdm_text_primary"
            android:textSize="28sp"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minWidth="56dp"
            android:focusable="true"
            android:nextFocusRight="@id/btnSettings"
            android:nextFocusDown="@id/layoutSelectDns" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/PDMText.Subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnLanguage"
            android:layout_toStartOf="@id/btnSettings"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="@string/dns_switcher"
            android:textSize="16sp"
            android:textColor="@color/pdm_text_primary"
            android:letterSpacing="0.02"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/pdm_btn_secondary"
            android:src="@drawable/ic_settings"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:focusable="true"
            android:nextFocusLeft="@id/btnLanguage"
            android:nextFocusDown="@id/layoutSelectDns"
            android:contentDescription="@string/settings_content_description" />
    </RelativeLayout>

    <!-- 1| Fournisseur DNS -->
    <TextView
        android:id="@+id/tvDnsProviderLabel"
        style="@style/PDMText.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dns_provider_label"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:id="@+id/layoutSelectDns"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/pdm_btn_secondary"
        android:focusable="true"
        android:clickable="true"
        android:nextFocusUp="@id/btnLanguage"
        android:nextFocusDown="@id/rowActivationToggle">

        <ImageView
            android:id="@+id/ivSelectedDnsIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="10dp"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="@null"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tvSelectDns"
            style="@style/PDMText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dns_select_button"
            android:textColor="@color/pdm_accent"
            android:gravity="center"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▸"
            android:textColor="@color/pdm_text_secondary"
            android:textSize="18sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 2| Activation -->
    <TextView
        android:id="@+id/tvActivationLabel"
        style="@style/PDMText.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/activation_label"
        android:layout_marginBottom="4dp" />

    <!-- Toggle activation : row focusable + Switch (Android TV friendly).
         Le row capte le focus, le Switch lui-même n'est pas focusable seul.
         FrameLayout pour que le texte soit centré au milieu de la row,
         le Switch superposé à droite sans déplacer le texte. -->
    <FrameLayout
        android:id="@+id/rowActivationToggle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/pdm_btn_secondary"
        android:foreground="@drawable/btn_focus_foreground"
        android:focusable="true"
        android:clickable="true"
        android:layout_marginBottom="8dp"
        android:nextFocusUp="@id/layoutSelectDns"
        android:nextFocusDown="@id/btnDomainTester">

        <TextView
            android:id="@+id/tvActivationStatus"
            style="@style/PDMText.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/activate"
            android:textColor="@color/pdm_accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swActivationToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:focusable="false"
            android:clickable="false" />
    </FrameLayout>

    <!-- Mobile layout : full-width vertical (Option B).
         Boutons fixes en haut + ScrollView qui contient les 2 cards full-width
         (Status + Rapport) — l'utilisateur scrolle pour voir le rapport sous le
         status quand le tel est court. Sur tablette/TV : layout-television/. -->
    <LinearLayout
        android:id="@+id/layoutToolsPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/pdm_card_bg"
        android:padding="10dp">

        <!-- Outils (gauche) + Rapport (droite) — swap fait après le déplacement des
             infos appareil dans le panneau status, pour aligner colonne outils sur
             colonne status info ci-dessous. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnDomainTester"
                style="@style/PDMButton"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/quick_dns_test_button"
                android:textSize="12sp"
                android:focusable="true"
                android:nextFocusUp="@id/rowActivationToggle"
                android:nextFocusRight="@id/btnGenerateReport"
                android:nextFocusDown="@id/btnSpeedtest" />

            <Button
                android:id="@+id/btnGenerateReport"
                style="@style/PDMButton.Primary"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/generate_report_button"
                android:textSize="12sp"
                android:focusable="true"
                android:nextFocusUp="@id/rowActivationToggle"
                android:nextFocusLeft="@id/btnDomainTester"
                android:nextFocusDown="@id/btnShareReport" />
        </LinearLayout>

        <!-- Speedtest (gauche) + Partager (droite) — symétrique row précédente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnSpeedtest"
                style="@style/PDMButton"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/internet_speedtest_advanced"
                android:textSize="12sp"
                android:focusable="true"
                android:nextFocusUp="@id/btnDomainTester"
                android:nextFocusRight="@id/btnShareReport"
                android:nextFocusDown="@id/wrapReport" />

            <Button
                android:id="@+id/btnShareReport"
                style="@style/PDMButton.Primary"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/share_report_button"
                android:textSize="12sp"
                android:focusable="true"
                android:nextFocusUp="@id/btnGenerateReport"
                android:nextFocusLeft="@id/btnSpeedtest"
                android:nextFocusDown="@id/wrapReport" />
        </LinearLayout>

        <!-- Mobile : 2 cards empilées full-width (Status + Rapport) dans un ScrollView.
             Le contenu peut dépasser sur petit écran ; user scrolle pour voir le rapport. -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:fillViewport="true"
            android:focusable="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/wrapStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/pdm_card_bg">
                    <TextView
                        android:id="@+id/tvStatusInfo"
                        style="@style/PDMText.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_active_dns"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/pdm_text_secondary"
                        android:padding="10dp" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/wrapReport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/pdm_card_bg">
                    <TextView
                        android:id="@+id/tvReportContent"
                        style="@style/PDMText.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_report_yet"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/pdm_text_secondary"
                        android:padding="10dp" />
                </FrameLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
