<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pdm_background"
    android:padding="16dp">

    <!-- Top bar: Back + Title -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:descendantFocusability="afterDescendants">
        <Button
            android:id="@+id/btnBack"
            style="@style/PDMBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_arrow"
            android:layout_gravity="start|center_vertical"
            android:nextFocusDown="@id/btnStartStop"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dns_speedtest_title"
            android:textColor="@color/pdm_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center"/>
    </FrameLayout>

    <!-- Start/Stop button + current test progress (same line) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dns_speedtest_button"
            android:background="@drawable/pdm_btn_primary"
            android:foreground="@drawable/btn_focus_foreground"
            android:textColor="@color/pdm_text_primary"
            android:textStyle="bold"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:focusable="true"
            android:nextFocusUp="@id/btnBack"
            android:nextFocusDown="@id/scrollProviders"
            android:nextFocusRight="@id/wrapTopRanking"/>

        <TextView
            android:id="@+id/tvCurrentTest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textColor="@color/pdm_text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:maxLines="3"
            android:text="@string/speedtest_waiting"
            android:background="@color/pdm_background"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Bottom 3 colonnes : Providers | Top5+Recommandé | Classement complet.
         Chaque colonne ranking utilise le pattern FrameLayout wrapper (focusable
         + foreground border) + ScrollView interne (non-focusable). Sans ce
         wrapper, le focus border ne suivait pas les bounds réelles et le
         contenu scrollable débordait visuellement. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- COL 1 : Providers (expandable) -->
        <ScrollView
            android:id="@+id/scrollProviders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@color/pdm_background"
            android:padding="6dp"
            android:fillViewport="true"
            android:focusable="false"
            android:descendantFocusability="afterDescendants"
            android:nextFocusUp="@id/btnStartStop"
            android:nextFocusRight="@id/wrapTopRanking">

            <LinearLayout
                android:id="@+id/layoutProviders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>

        <!-- COL 2 : Meilleurs DNS + Recommandé -->
        <FrameLayout
            android:id="@+id/wrapTopRanking"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@color/pdm_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:foregroundGravity="fill"
            android:focusable="true"
            android:descendantFocusability="blocksDescendants"
            android:nextFocusUp="@id/btnStartStop"
            android:nextFocusLeft="@id/scrollProviders"
            android:nextFocusRight="@id/wrapFullRanking">
            <ScrollView
                android:id="@+id/scrollTopRanking"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:fillViewport="false"
                android:focusable="false"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:scrollbarSize="6dp"
                android:scrollbarThumbVertical="@color/pdm_accent_alt">
                <TextView
                    android:id="@+id/tvTopRanking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/pdm_text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="1dp"
                    android:focusable="false"/>
            </ScrollView>
        </FrameLayout>

        <!-- COL 3 : Classement complet -->
        <FrameLayout
            android:id="@+id/wrapFullRanking"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@color/pdm_background"
            android:foreground="@drawable/btn_focus_foreground"
            android:foregroundGravity="fill"
            android:focusable="true"
            android:descendantFocusability="blocksDescendants"
            android:nextFocusUp="@id/btnStartStop"
            android:nextFocusLeft="@id/wrapTopRanking">
            <ScrollView
                android:id="@+id/scrollFullRanking"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:fillViewport="false"
                android:focusable="false"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:scrollbarSize="6dp"
                android:scrollbarThumbVertical="@color/pdm_accent_alt">
                <TextView
                    android:id="@+id/tvFullRanking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/pdm_text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="1dp"
                    android:focusable="false"/>
            </ScrollView>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
