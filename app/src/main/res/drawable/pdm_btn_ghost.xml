<?xml version="1.0" encoding="utf-8"?>
<!--
  Bouton "ghost" pour actions footer (Soutenir, À propos) : pas de remplissage,
  bordure discrète, sert de navigation/méta. Garde un focus ring via
  btn_focus_foreground sur la View.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@color/pdm_surface_pressed" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="@color/pdm_border" />
        </shape>
    </item>
</selector>
