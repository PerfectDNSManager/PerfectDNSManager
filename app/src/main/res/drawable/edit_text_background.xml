<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/pdm_surface_elevated" />
            <stroke android:width="3dp" android:color="@color/pdm_accent_gold" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/pdm_border" />
            <stroke android:width="1dp" android:color="@color/pdm_border" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</selector>
