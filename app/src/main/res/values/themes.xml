<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PerfectDNSChanger" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/pdm_background</item>
        <item name="android:colorBackground">@color/pdm_background</item>
        <item name="colorPrimary">@color/pdm_accent</item>
        <item name="colorPrimaryDark">@color/pdm_background</item>
        <item name="colorAccent">@color/pdm_accent</item>
        <item name="android:textColorPrimary">@color/pdm_text_primary</item>
        <item name="android:textColorSecondary">@color/pdm_text_secondary</item>
        <item name="android:textColorHint">@color/pdm_text_disabled</item>
        <item name="android:statusBarColor">@color/pdm_background</item>
        <item name="android:navigationBarColor">@color/pdm_background</item>
        <item name="alertDialogTheme">@style/PDMAlertDialog</item>
        <!-- Contraste track toggle OFF : gris clair sur blanc (light mode) devenait invisible.
             colorControlNormal pilote la teinte de piste de toute checkbox/switch non cochée. -->
        <item name="android:colorControlNormal">@color/pdm_toggle_off</item>
    </style>

    <!-- ─── Dialogue ─── -->
    <style name="PDMAlertDialog" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="android:background">@color/pdm_surface_elevated</item>
        <item name="android:windowBackground">@drawable/pdm_dialog_bg</item>
        <item name="android:textColorPrimary">@color/pdm_text_primary</item>
        <item name="android:textColorSecondary">@color/pdm_text_secondary</item>
        <item name="colorAccent">@color/pdm_accent</item>
        <item name="colorControlActivated">@color/pdm_accent</item>
        <item name="android:colorControlNormal">@color/pdm_text_secondary</item>
    </style>

    <!-- ─── Typographie ─── -->
    <style name="PDMText" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/pdm_text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="PDMText.Title">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="PDMText.Subtitle">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/pdm_text_primary</item>
    </style>

    <style name="PDMText.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="PDMText.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/pdm_text_secondary</item>
    </style>

    <style name="PDMText.Mono">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/pdm_text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- ─── Boutons ─── -->
    <style name="PDMButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/pdm_btn_secondary</item>
        <item name="android:textColor">@color/pdm_text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:foreground">@drawable/pdm_focus_ring</item>
    </style>

    <style name="PDMButton.Primary">
        <item name="android:background">@drawable/pdm_btn_primary</item>
        <item name="android:textColor">@color/pdm_accent</item>
    </style>

    <style name="PDMButton.Danger">
        <item name="android:background">@drawable/pdm_btn_danger</item>
        <item name="android:textColor">@color/pdm_danger</item>
    </style>

    <style name="PDMButton.Ghost">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/pdm_text_secondary</item>
    </style>

    <!-- ─── Inputs ─── -->
    <style name="PDMInput" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/pdm_input_bg</item>
        <item name="android:textColor">@color/pdm_text_primary</item>
        <item name="android:textColorHint">@color/pdm_text_disabled</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:minHeight">44dp</item>
    </style>

    <!-- ─── Card / Surface ─── -->
    <style name="PDMCard">
        <item name="android:background">@drawable/pdm_card_bg</item>
        <item name="android:padding">16dp</item>
    </style>

</resources>
